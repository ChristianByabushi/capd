# Copy this file to .env and fill in your values
# .env is NEVER committed to git

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=capd_db

# App
BASE_URL=http://localhost/capd
APP_ENV=development
DEFAULT_LANG=fr

# Security — generate a long random string
CSRF_SECRET=change_me_to_something_long_and_random
